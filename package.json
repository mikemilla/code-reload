{
  "name": "code-reload",
  "version": "0.1.1",
  "description": "On-device live code editor and AI agent for React Native",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "src/",
    "ios/",
    "android/build.gradle",
    "android/src/",
    "scripts/",
    "code-reload.podspec"
  ],
  "bin": {
    "code-reload-snapshot": "scripts/code-reload-snapshot.js"
  },
  "scripts": {
    "typescript": "tsc --noEmit",
    "prepublishOnly": "npm run typescript",
    "snapshot": "node scripts/code-reload-snapshot.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikemilla/code-reload.git"
  },
  "bugs": "https://github.com/mikemilla/code-reload/issues",
  "homepage": "https://github.com/mikemilla/code-reload#readme",
  "keywords": [
    "react-native",
    "live-reload",
    "devtools",
    "ai"
  ],
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.72.0",
    "@react-native-async-storage/async-storage": ">=1.0.0",
    "react-native-safe-area-context": ">=4.0.0",
    "sucrase": ">=3.0.0"
  },
  "devDependencies": {
    "react-native-safe-area-context": "^5.5.2",
    "typescript": "^5.0.0"
  },
  "license": "MIT"
}
